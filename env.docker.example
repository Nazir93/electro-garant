# Скопируйте в файл `.env` в корне репозитория (рядом с docker-compose.yml).
# Docker Compose подхватит переменные для сервиса postgres.
#
# ВАЖНО: POSTGRES_PASSWORD должен совпадать с паролем в frontend/.env.local
# внутри DATABASE_URL (postgresql://electro:ПАРОЛЬ@127.0.0.1:5432/electro).

POSTGRES_PASSWORD=changeme
