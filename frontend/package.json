{
  "name": "garant-montazh",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=prisma/schema.prisma && next build",
    "build:with-prisma": "prisma generate --schema=prisma/schema.prisma && next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:push:server": "prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:verify": "dotenv -e .env.local -- node scripts/verify-db.cjs",
    "db:seed-price": "dotenv -e .env.local -- npx tsx scripts/seed-price-calculator.ts",
    "db:seed-price:prod": "dotenv -e .env -- npx tsx scripts/seed-price-calculator.ts",
    "seo:export-landings": "npx tsx scripts/export-service-landings.ts",
    "docker:db": "docker compose -f ../docker-compose.yml up -d postgres",
    "db:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db-tunnel.ps1",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload electro-next"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.20.0",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@yandex/smart-captcha": "^2.9.1",
    "clsx": "^2.1.0",
    "embla-carousel-react": "^8.3.0",
    "framer-motion": "^11.0.0",
    "lenis": "^1.3.19",
    "lucide-react": "^0.460.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.53.0",
    "resend": "^4.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
