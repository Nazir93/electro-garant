# Шаблон переменных. На VPS см. DEPLOY-SERVER.md (там же про NEXTAUTH_URL и админку).
#
# === Database ===
# По умолчанию — PostgreSQL на этом ПК (порт 5432), пользователь и база electro, затем: npm run db:push
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/electro?schema=public"
# Редко: SSH-туннель к Postgres на VPS (порт 5433) — см. scripts/db-tunnel.ps1 и frontend/package.json (db:tunnel).

# === Site ===
NEXT_PUBLIC_SITE_URL="https://gmont.ru"
NEXT_PUBLIC_SITE_NAME="Гарант Монтаж"
NEXT_PUBLIC_CITY="Сочи"

# Ссылка на чат Max (хедер/футер; при пустом значении в БД — дефолт из constants)
NEXT_PUBLIC_MAX_CHAT_URL="https://max.ru/u/f9LHodD0cOICVt6F_SbXekYin0iKseqgg53Vo-E4sCJ1sXjkB0Bs18LxWUg"

# === Yandex SmartCaptcha (защита форм от ботов) ===
# Ключи: https://cloud.yandex.com/ru/services/smartcaptcha
NEXT_PUBLIC_YANDEX_SMARTCAPTCHA_CLIENT_KEY=""
YANDEX_SMARTCAPTCHA_SERVER_KEY=""

# === Email (Resend) ===
RESEND_API_KEY=""
NOTIFICATION_EMAIL="info@garantmontazh.ru"

# === Telegram Bot (уведомления о заявках из POST /api/leads) ===
# Токен: @BotFather → /newbot → скопировать токен.
# Chat ID: личный чат — напишите боту /start, затем откройте в браузере:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  и найдите "chat":{"id": ...}
# Группа: добавьте бота в группу, дайте право писать; id группы обычно отрицательный (в getUpdates).
# Альтернатива: задать те же значения в админке (/admin → Настройки → Telegram-уведомления), если в .env пусто.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Опционально: несколько получателей через запятую (если задано — используется вместо одного TELEGRAM_CHAT_ID)
# TELEGRAM_CHAT_IDS="-1001234567890,-1009876543210"
# Опционально: ID темы в супергруппе с включёнными темами (forum topic)
# TELEGRAM_MESSAGE_THREAD_ID="123"

# === Admin Auth ===
ADMIN_EMAIL="admin@garantmontazh.ru"
ADMIN_SECRET="change-this-to-a-secure-random-string"
NEXTAUTH_SECRET="change-this-to-another-secure-random-string"
# Обязательно публичный URL сайта с тем же хостом и схемой, что в браузере (не IP и не http://localhost).
# Иначе вход в /admin по домену не сработает — только по IP.
NEXTAUTH_URL="https://gmont.ru"

# === Аналитика (fallback, если в админке не заданы ID в настройках сайта) ===
NEXT_PUBLIC_YANDEX_METRIKA_ID=""
NEXT_PUBLIC_GA_ID=""
